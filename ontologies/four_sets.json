        "negative": "Reductionist",
        "description": "Observation that enlightens vs. analysis that drains meaning."
      },
      {
        "positive": "Mythic",
        "negative": "Delusional",
        "description": "Symbolic imagination vs. self-deceiving fantasy."
      },
      {
        "positive": "Rhetorical",
        "negative": "Manipulative",
        "description": "Persuasive teaching vs. propaganda and deceit."
      },
      {
        "positive": "Mystic",
        "negative": "Obscurantist",
        "description": "Intuitive unity vs. mystification and vagueness."
      }
    ]
