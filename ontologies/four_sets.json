      },
      {
        "positive": "Anger (Righteous)",
        "negative": "Rage (Blind)",
        "description": "Asserting justice vs. destructive fury."
      },
      {
        "positive": "Curiosity",
        "negative": "Fear",
        "description": "Openness vs. retreat and paralysis."
